</category>

<category>
  <pattern>ARE * AND * SISTERS</pattern>
  <template>
    <set name="verify_p1"><star/></set>
    <set name="rel">sister</set>
    <set name="p1"><star index="2"/></set>
    VERIFY
  </template>
</category>

<category>
  <pattern>ARE * AND * COUSINS</pattern>
  <template>
    <set name="verify_p1"><star/></set>
    <set name="rel">cousin</set>
