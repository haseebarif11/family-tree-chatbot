<?xml version="1.0" encoding="UTF-8"?>
<aiml version="1.0.1">

<!-- Relationship questions: set rel + p1; Python sets p2; second respond fills template -->

<category>
  <pattern>WHO ARE THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

