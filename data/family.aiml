<!-- Help -->

<category>
  <pattern>HELP</pattern>
  <template>
You can ask relationship questions in many ways, for example:
- Who is the father of Ali?
- What is the grandmother of Usman?
- Tell me the sibling of Ali
- Father of Ali
- How old is Haider?
List queries (lists everyone in that group):
- male / males / all males
- female / females / all females
- parents / children / siblings / sons / daughters
- ages / married couples
- MEMBERS — every family name
  </template>
</category>

<!-- Members list -->

<category>
  <pattern>MEMBERS</pattern>
  <template>MEMBERS_LIST</template>
</category>

<!-- Subject-first / Inverse relationship queries: set inverse, rel, p1 -->

<category>
  <pattern>* IS THE * OF</pattern>
  <template>
    <set name="inverse">true</set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="1"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>* IS A * OF</pattern>
  <template>
    <set name="inverse">true</set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="1"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>* IS AN * OF</pattern>
  <template>
    <set name="inverse">true</set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="1"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>* IS * OF</pattern>
  <template>
    <set name="inverse">true</set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="1"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<!-- Verification queries: set verify_p1, rel, and p1; return VERIFY -->

<category>
  <pattern>IS * THE * OF *</pattern>
  <template>
    <set name="verify_p1"><star/></set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="3"/></set>
    VERIFY
  </template>
</category>

<category>
  <pattern>IS * A * OF *</pattern>
  <template>
    <set name="verify_p1"><star/></set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="3"/></set>
    VERIFY
  </template>
</category>

<category>
  <pattern>IS * AN * OF *</pattern>
  <template>
    <set name="verify_p1"><star/></set>
    <set name="rel"><star index="2"/></set>
    <set name="p1"><star index="3"/></set>
